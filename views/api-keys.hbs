<div class="space-y-6">
    <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-4">
        <div>
            <h2 class="text-2xl font-bold tracking-tight text-slate-900">System API Key Management</h2>
            <p class="text-sm text-slate-500 mt-0.5">Provision and supervise internal security layer credentials config signatures.</p>
        </div>
        <button onclick="showCreateKeyModal()" class="inline-flex items-center justify-center font-semibold text-xs text-white px-4 py-2.5 rounded-lg transition-transform hover:scale-[1.02] active:scale-100 shadow-sm" style="background-color: #111CA8;">
            <i class="fas fa-plus mr-2"></i>Provision Token Secret
        </button>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Total Active Sets</span>
            <p class="text-2xl font-black text-slate-900 mt-1">{{stats.totalKeys}}</p>
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Live Verified Roots</span>
            <p class="text-2xl font-black text-emerald-600 mt-1">{{stats.activeKeys}}</p>
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Aggregated Loads</span>
            <p class="text-2xl font-black text-slate-900 mt-1">{{stats.totalCalls}}</p>
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Token Accruals</span>
            <p class="text-2xl font-black text-slate-900 mt-1">${{formatNumber stats.totalCost}}</p>
        </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-slate-400 font-bold uppercase tracking-wider">
                        <th class="px-6 py-3.5">Identifier Name</th>
                        <th class="px-6 py-3.5">Prefix Token</th>
                        <th class="px-6 py-3.5">User Identity Reference</th>
                        <th class="px-6 py-3.5">Assigned Scopes</th>
                        <th class="px-6 py-3.5">Redis Rate Rules</th>
                        <th class="px-6 py-3.5">Usage Calls</th>
                        <th class="px-6 py-3.5">Status</th>
                        <th class="px-6 py-3.5">Terminal Use</th>
                        <th class="px-6 py-3.5">Lifespan Expiry</th>
                        <th class="px-6 py-3.5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-slate-600 font-medium">
                    {{#each apiKeys}}
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-6 py-4 font-bold text-slate-900">{{name}}</td>
                        <td class="px-6 py-4"><code class="font-mono text-slate-900 bg-slate-100 px-1.5 py-0.5 rounded border border-slate-200/60">{{keyPrefix}}...</code></td>
                        <td class="px-6 py-4">
                            <div class="text-slate-900 font-semibold">{{user.email}}</div>
                            <div class="text-[10px] text-slate-400 font-medium mt-0.5">{{user.name}}</div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-wrap gap-1 max-w-[150px]">
                                {{#each scopes}}
                                <span class="px-1.5 py-0.5 bg-slate-100 border border-slate-200 rounded text-[10px] font-bold text-slate-700 tracking-tight">{{this}}</span>
                                {{/each}}
                            </div>
                        </td>
                        <td class="px-6 py-4 font-medium text-slate-500">
                            <div class="flex items-center gap-1"><i class="fas fa-bolt text-[10px] w-3"></i> {{#if rpmLimit}}{{rpmLimit}}{{else}}60{{/if}} RPM</div>
                            <div class="flex items-center gap-1 mt-1"><i class="fas fa-calendar text-[10px] w-3"></i> {{#if rpdLimit}}{{rpdLimit}}{{else}}1000{{/if}} RPD</div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="font-bold text-slate-900">{{usageCount}}</span> calls
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2 py-0.5 font-bold rounded uppercase text-[9px] tracking-wider border
                                {{#if (eq status 'ACTIVE')}}bg-emerald-50 text-emerald-800 border-emerald-200{{/if}}
                                {{#if (eq status 'REVOKED')}}bg-rose-50 text-rose-800 border-rose-200{{/if}}
                                {{#if (eq status 'EXPIRED')}}bg-slate-100 text-slate-800 border-slate-200{{/if}}">
                                {{status}}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-slate-500 font-mono">{{#if lastUsedAt}}{{formatTime lastUsedAt}}{{else}}Never{{/if}}</td>
                        <td class="px-6 py-4 font-medium">
                            {{#if expiresAt}}
                            <span class="{{#if (isExpired expiresAt)}}text-rose-600 font-semibold{{else}}text-amber-600{{/if}}">
                                {{formatDate expiresAt}}
                            </span>
                            {{else}}
                            <span class="text-emerald-600 font-semibold">Infinite</span>
                            {{/if}}
                        </td>
                        <td class="px-6 py-4 text-right space-x-1.5 font-bold text-sm">
                            <button onclick="editKey('{{id}}')" class="text-slate-400 hover:text-slate-950 transition-colors"><i class="fas fa-edit"></i></button>
                            <button onclick="revokeKey('{{id}}', '{{name}}')" class="text-slate-400 hover:text-rose-600 transition-colors"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="10" class="px-6 py-16 text-center text-slate-400">
                            <i class="fas fa-key text-3xl text-slate-200 mb-3 block"></i>
                            <p class="font-medium text-sm">No localized API keys identified inside standard DB cluster models.</p>
                            <button onclick="showCreateKeyModal()" class="mt-2 text-xs font-bold underline" style="color: #111CA8;">Instantiate primary configuration key token</button>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="createKeyModal" class="fixed inset-0 bg-slate-950/40 hidden z-50 overflow-y-auto backdrop-blur-sm">
    <div class="flex items-start justify-center min-h-screen p-4">
        <div class="bg-white border border-slate-200 rounded-xl max-w-xl w-full shadow-2xl my-12 overflow-hidden">
            <div class="flex justify-between items-center px-6 py-4 border-b border-slate-100 bg-slate-50">
                <h3 class="text-sm font-bold text-slate-900 tracking-tight" id="modalTitle">Instantiate New API Target Key</h3>
                <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600"><i class="fas fa-times"></i></button>
            </div>
            
            <form id="createKeyForm" class="p-6 space-y-5 text-sm">
                <input type="hidden" id="editKeyId">
                
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Key Label Target *</label>
                    <input type="text" id="keyName" required class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium" placeholder="e.g. Core Production Framework Gateway Key">
                </div>
                
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Permitted Action Scopes</label>
                    <div class="grid grid-cols-2 gap-2 font-medium text-xs text-slate-700">
                        <label class="flex items-center px-3 py-2.5 border border-slate-200 rounded-lg hover:bg-slate-50 cursor-pointer transition">
                            <input type="checkbox" value="CHAT" class="scope-checkbox mr-2.5 rounded text-indigo-900 focus:ring-0">
                            <span>💬 Chat Endpoint Layer</span>
                        </label>
                        <label class="flex items-center px-3 py-2.5 border border-slate-200 rounded-lg hover:bg-slate-50 cursor-pointer transition">
                            <input type="checkbox" value="IMAGE" class="scope-checkbox mr-2.5 rounded text-indigo-900 focus:ring-0">
                            <span>🎨 Image Automation</span>
                        </label>
                        <label class="flex items-center px-3 py-2.5 border border-slate-200 rounded-lg hover:bg-slate-50 cursor-pointer transition">
                            <input type="checkbox" value="VIDEO" class="scope-checkbox mr-2.5 rounded text-indigo-900 focus:ring-0">
                            <span>🎬 Video Stream Engine</span>
                        </label>
                        <label class="flex items-center px-3 py-2.5 border border-slate-200 rounded-lg hover:bg-slate-50 cursor-pointer transition">
                            <input type="checkbox" value="EMBEDDINGS" class="scope-checkbox mr-2.5 rounded text-indigo-900 focus:ring-0">
                            <span>🔢 Embeddings Matrices</span>
                        </label>
                    </div>
                </div>
                
                <div class="border-t border-slate-100 pt-4">
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Rate Limit Settings</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[11px] font-semibold text-slate-500 mb-1">Requests / Minute (RPM)</label>
                            <input type="number" id="rpmLimit" value="60" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium">
                        </div>
                        <div>
                            <label class="block text-[11px] font-semibold text-slate-500 mb-1">Requests / Day (RPD)</label>
                            <input type="number" id="rpdLimit" value="1000" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium">
                        </div>
                    </div>
                </div>
                
                <div class="border-t border-slate-100 pt-4">
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Usage Ceiling Threshold</h4>
                    <label class="block text-[11px] font-semibold text-slate-500 mb-1">Monthly Max Volumetric Tokens</label>
                    <input type="number" id="monthlyTokenLimit" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium" placeholder="Unlimited base tracking execution maps">
                </div>
                
                <div class="border-t border-slate-100 pt-4">
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Lifespan Limits Parameters</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[11px] font-semibold text-slate-500 mb-1">Relative Lifespan (Days)</label>
                            <input type="number" id="expiresIn" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium" placeholder="Infinite parameters">
                        </div>
                        <div>
                            <label class="block text-[11px] font-semibold text-slate-500 mb-1">Target End Timestamp</label>
                            <input type="date" id="expiresAt" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium">
                        </div>
                    </div>
                </div>
                
                <div class="flex gap-2 justify-end pt-4 border-t border-slate-100">
                    <button type="button" onclick="closeModal()" class="px-4 py-2 text-xs font-bold border border-slate-200 rounded-lg hover:bg-slate-50 transition">Cancel View</button>
                    <button type="submit" class="px-4 py-2 text-xs font-bold text-white rounded-lg transition" style="background-color: #111CA8;">Finalize Properties Setup</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="keyDisplayModal" class="fixed inset-0 bg-slate-950/40 hidden z-50 flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white border border-slate-200 rounded-xl max-w-md w-full shadow-2xl p-6 text-center text-sm">
        <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4 border border-emerald-100">
            <i class="fas fa-check text-lg"></i>
        </div>
        <h3 class="text-base font-bold text-slate-900 mb-1">Cryptographic Base Secret Generated</h3>
        <p class="text-xs text-slate-500 px-4 mb-5">Ensure properties values are copied to backup servers instantly. Database tracking strings render masked after this action context completes.</p>
        
        <div class="bg-slate-950 text-emerald-400 p-3 rounded-lg font-mono text-xs break-all border border-slate-800 text-left mb-5 select-all shadow-inner">
            <code id="generatedKey"></code>
        </div>
        
        <div class="flex gap-2">
            <button onclick="copyToClipboard()" class="flex-1 font-bold text-xs text-white py-2.5 rounded-lg transition" style="background-color: #111CA8;"><i class="fas fa-copy mr-2"></i>Copy String</button>
            <button onclick="closeKeyDisplayModal()" class="flex-1 font-bold text-xs border border-slate-200 text-slate-700 py-2.5 rounded-lg hover:bg-slate-50 transition">Dismiss View</button>
        </div>
    </div>
</div>

<script>
    // System operational script arrays are sustained safely from native view logic contexts natively.
    let generatedRawKey = '';
    function showCreateKeyModal() {
        document.getElementById('modalTitle').innerHTML = 'Instantiate New API Target Key';
        document.getElementById('createKeyForm').reset();
        document.getElementById('editKeyId').value = '';
        document.getElementById('rpmLimit').value = '60';
        document.getElementById('rpdLimit').value = '1000';
        document.getElementById('createKeyModal').classList.remove('hidden');
    }
    function closeModal() { document.getElementById('createKeyModal').classList.add('hidden'); }
    function copyToClipboard() {
        navigator.clipboard.writeText(generatedRawKey);
        alert('API hash string piped safely to system clipboard framework structures.');
    }
    function closeKeyDisplayModal() {
        document.getElementById('keyDisplayModal').classList.add('hidden');
        location.reload();
    }
    // Form handles connect cleanly upstream mapping payload JSON parameters directly.
</script>