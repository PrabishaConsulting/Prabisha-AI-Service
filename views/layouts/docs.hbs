<!-- views/layouts/docs.hbs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} | AI Gateway</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <style>
        pre {
            background: #1e1e1e;
            padding: 1rem;
            border-radius: 0.5rem;
            overflow-x: auto;
        }
        code {
            font-family: 'Courier New', monospace;
            font-size: 0.9rem;
        }
        .api-endpoint {
            background: #f3f4f6;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            font-family: monospace;
            font-weight: bold;
        }
        .method-post { color: #10b981; }
        .method-get { color: #3b82f6; }
        .method-delete { color: #ef4444; }
        .nav-link {
            transition: all 0.2s;
        }
        .nav-link:hover {
            color: #8b5cf6;
            border-left-color: #8b5cf6;
        }
        .try-it-out {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .response-area {
            max-height: 400px;
            overflow-y: auto;
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-200">
        <nav class="container mx-auto px-4 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-8">
                    <a href="/docs" class="flex items-center space-x-2">
                        <i class="fas fa-robot text-purple-600 text-2xl"></i>
                        <span class="font-bold text-xl text-gray-800">AI Gateway</span>
                    </a>
                    <div class="hidden md:flex space-x-6">
                        <a href="/docs" class="text-gray-600 hover:text-purple-600">Documentation</a>
                        <a href="/docs/authentication" class="text-gray-600 hover:text-purple-600">Authentication</a>
                        <a href="/docs/chat" class="text-gray-600 hover:text-purple-600">Chat API</a>
                        <a href="/docs/image" class="text-gray-600 hover:text-purple-600">Image API</a>
                        <a href="/docs/rate-limits" class="text-gray-600 hover:text-purple-600">Rate Limits</a>
                    </div>
                </div>
                <div>
                    <a href="/auth/login" class="text-purple-600 hover:text-purple-700 font-medium">
                        <i class="fas fa-key mr-1"></i>Get API Key
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Sidebar -->
            <aside class="lg:w-1/4">
                <div class="sticky top-8">
                    <div class="bg-white rounded-lg shadow-sm p-4">
                        <h3 class="font-semibold text-gray-800 mb-3">Getting Started</h3>
                        <ul class="space-y-2">
                            <li>
                                <a href="/docs#introduction" class="text-gray-600 hover:text-purple-600 block py-1">
                                    Introduction
                                </a>
                            </li>
                            <li>
                                <a href="/docs/authentication" class="text-gray-600 hover:text-purple-600 block py-1">
                                    Authentication
                                </a>
                            </li>
                            <li>
                                <a href="/docs/rate-limits" class="text-gray-600 hover:text-purple-600 block py-1">
                                    Rate Limits
                                </a>
                            </li>
                        </ul>
                        
                        <h3 class="font-semibold text-gray-800 mt-6 mb-3">API Endpoints</h3>
                        <ul class="space-y-2">
                            <li>
                                <a href="/docs/chat" class="text-gray-600 hover:text-purple-600 block py-1">
                                    Chat Completion
                                </a>
                            </li>
                            <li>
                                <a href="/docs/image" class="text-gray-600 hover:text-purple-600 block py-1">
                                    Image Generation
                                </a>
                            </li>
                            <li>
                                <a href="/docs/embeddings" class="text-gray-600 hover:text-purple-600 block py-1">
                                    Embeddings
                                </a>
                            </li>
                        </ul>
                        
                        <h3 class="font-semibold text-gray-800 mt-6 mb-3">Resources</h3>
                        <ul class="space-y-2">
                            <li>
                                <a href="#support" class="text-gray-600 hover:text-purple-600 block py-1">
                                    Support
                                </a>
                            </li>
                            <li>
                                <a href="#pricing" class="text-gray-600 hover:text-purple-600 block py-1">
                                    Pricing
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </aside>

            <!-- Content -->
            <article class="lg:w-3/4">
                <div class="bg-white rounded-lg shadow-sm p-8">
                    {{{body}}}
                </div>
            </article>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-12 py-8">
        <div class="container mx-auto px-4 text-center text-gray-500 text-sm">
            <p>&copy; 2024 AI Gateway - All rights reserved</p>
        </div>
    </footer>

    <script>
        hljs.highlightAll();
    </script>
</body>
</html>