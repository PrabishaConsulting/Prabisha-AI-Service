<div class="space-y-8">
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">System Metrics Dashboard</h2>
        <p class="text-sm text-slate-500 mt-0.5">Real-time status metrics reporting unified transaction overhead pipelines.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Total Transactions</p>
                    <p class="text-3xl font-black text-slate-900 mt-2">{{stats.totalCalls}}</p>
                    <span class="inline-flex items-center text-xs font-medium text-emerald-600 mt-2 gap-1">
                        <i class="fas fa-arrow-up text-[10px]"></i> +{{stats.growth}}% vs history
                    </span>
                </div>
                <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-slate-50 border border-slate-100">
                    <i class="fas fa-chart-line text-slate-700"></i>
                </div>
            </div>
        </div>
        
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Active Token Keys</p>
                    <p class="text-3xl font-black text-slate-900 mt-2">{{stats.activeKeys}}</p>
                    <p class="text-xs text-slate-400 font-medium mt-2">{{stats.totalKeys}} generated keys</p>
                </div>
                <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-slate-50 border border-slate-100">
                    <i class="fas fa-key text-slate-700"></i>
                </div>
            </div>
        </div>
        
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Active Providers</p>
                    <p class="text-3xl font-black text-slate-900 mt-2">{{stats.activeProviders}}</p>
                    <p class="text-xs text-slate-400 font-medium mt-2">{{stats.totalProviders}} nodes synced</p>
                </div>
                <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-slate-50 border border-slate-100">
                    <i class="fas fa-cloud text-slate-700"></i>
                </div>
            </div>
        </div>
        
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Accumulated Spend</p>
                    <p class="text-3xl font-black text-slate-900 mt-2">${{formatNumber stats.totalCost}}</p>
                    <p class="text-xs font-semibold mt-2" style="color: #DE6A2C;">Current Cycle: ${{formatNumber stats.monthlyCost}}</p>
                </div>
                <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-orange-50 border border-orange-100">
                    <i class="fas fa-dollar-sign" style="color: #DE6A2C;"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm lg:col-span-2">
            <h3 class="text-sm font-bold text-slate-800 mb-4 tracking-tight">Proxy Load Vector (Last 7 Days)</h3>
            <div class="h-64 relative">
                <canvas id="usageChart"></canvas>
            </div>
        </div>
        
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <h3 class="text-sm font-bold text-slate-800 mb-4 tracking-tight">Provider Allocation Share</h3>
            <div class="h-64 relative">
                <canvas id="providerChart"></canvas>
            </div>
        </div>
    </div>
    
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
        <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h3 class="text-sm font-bold text-slate-800 tracking-tight">Recent Execution Streams</h3>
            <a href="/admin/analytics" class="text-xs font-semibold hover:underline" style="color: #111CA8;">View Detailed Registry →</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-xs font-bold text-slate-400 uppercase tracking-wider">
                        <th class="px-6 py-3">Timestamp</th>
                        <th class="px-6 py-3">Identity Owner</th>
                        <th class="px-6 py-3">Endpoint Endpoint</th>
                        <th class="px-6 py-3">Node Core</th>
                        <th class="px-6 py-3">Status</th>
                        <th class="px-6 py-3">Latency Delta</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-slate-600 font-medium">
                    {{#each recentActivity}}
                    <tr class="hover:bg-slate-50/80 transition-colors">
                        <td class="px-6 py-4 text-xs font-mono">{{formatTime createdAt}}</td>
                        <td class="px-6 py-4 text-slate-900 text-xs">{{user.email}}</td>
                        <td class="px-6 py-4 font-mono text-xs text-slate-500">{{endpointPath}}</td>
                        <td class="px-6 py-4 text-xs">{{provider.name}}</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-200">
                                {{status}}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-xs font-mono text-slate-900">{{latencyMs}}ms</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const usageCtx = document.getElementById('usageChart').getContext('2d');
        new Chart(usageCtx, {
            type: 'line',
            data: {
                labels: {{{json usageLabels}}},
                datasets: [{
                    label: 'Requests Count',
                    data: {{{json usageData}}},
                    borderColor: '#111CA8',
                    backgroundColor: 'rgba(17, 28, 168, 0.02)',
                    borderWidth: 2,
                    tension: 0.15,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { color: '#f1f5f9' }, ticks: { font: { size: 10 } } },
                    x: { grid: { display: false }, ticks: { font: { size: 10 } } }
                }
            }
        });
        
        const providerCtx = document.getElementById('providerChart').getContext('2d');
        new Chart(providerCtx, {
            type: 'doughnut',
            data: {
                labels: {{{json providerLabels}}},
                datasets: [{
                    data: {{{json providerData}}},
                    backgroundColor: ['#111CA8', '#DE6A2C', '#334155', '#475569', '#64748b']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } } },
                cutout: '75%'
            }
        });
    });
</script>