<div class="space-y-6">
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Total API Calls</p>
                    <p class="text-3xl font-bold text-gray-800 mt-1">{{stats.totalCalls}}</p>
                    <p class="text-xs text-green-600 mt-2">
                        <i class="fas fa-arrow-up"></i> +{{stats.growth}}% from last month
                    </p>
                </div>
                <div class="w-12 h-12 rounded-full bg-purple-100 flex items-center justify-center">
                    <i class="fas fa-chart-line text-purple-600 text-xl"></i>
                </div>
            </div>
        </div>
        
        <div class="card p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Active API Keys</p>
                    <p class="text-3xl font-bold text-gray-800 mt-1">{{stats.activeKeys}}</p>
                    <p class="text-xs text-gray-500 mt-2">{{stats.totalKeys}} total keys</p>
                </div>
                <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center">
                    <i class="fas fa-key text-green-600 text-xl"></i>
                </div>
            </div>
        </div>
        
        <div class="card p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Active Providers</p>
                    <p class="text-3xl font-bold text-gray-800 mt-1">{{stats.activeProviders}}</p>
                    <p class="text-xs text-gray-500 mt-2">{{stats.totalProviders}} total configured</p>
                </div>
                <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center">
                    <i class="fas fa-cloud text-blue-600 text-xl"></i>
                </div>
            </div>
        </div>
        
        <div class="card p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Total Cost (USD)</p>
                    <p class="text-3xl font-bold text-gray-800 mt-1">${{formatNumber stats.totalCost}}</p>
                    <p class="text-xs text-orange-600 mt-2">This month: ${{formatNumber stats.monthlyCost}}</p>
                </div>
                <div class="w-12 h-12 rounded-full bg-orange-100 flex items-center justify-center">
                    <i class="fas fa-dollar-sign text-orange-600 text-xl"></i>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Charts Row -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Usage Chart -->
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Usage Overview (Last 7 Days)</h3>
            <canvas id="usageChart" height="250"></canvas>
        </div>
        
        <!-- Provider Distribution -->
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Provider Distribution</h3>
            <canvas id="providerChart" height="250"></canvas>
        </div>
    </div>
    
    <!-- Recent Activity -->
    <div class="card p-6">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-800">Recent Activity</h3>
            <a href="/admin/analytics" class="text-purple-600 text-sm hover:underline">View all →</a>
        </div>
        <div class="table-container">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Time</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Endpoint</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Provider</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Latency</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {{#each recentActivity}}
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 text-sm text-gray-600">{{formatTime createdAt}}</td>
                        <td class="px-6 py-4 text-sm text-gray-900">{{user.email}}</td>
                        <td class="px-6 py-4 text-sm text-gray-600">{{endpointPath}}</td>
                        <td class="px-6 py-4 text-sm text-gray-600">{{provider.name}}</td>
                        <td class="px-6 py-4">
                            <span class="status-badge status-{{statusClass status}}">
                                {{status}}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-600">{{latencyMs}}ms</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // Usage Chart
    const usageCtx = document.getElementById('usageChart').getContext('2d');
    new Chart(usageCtx, {
        type: 'line',
        data: {
            labels: {{{json usageLabels}}},
            datasets: [{
                label: 'Total Requests',
                data: {{{json usageData}}},
                borderColor: '#8b5cf6',
                backgroundColor: 'rgba(139, 92, 246, 0.1)',
                tension: 0.4,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { position: 'bottom' }
            }
        }
    });
    
    // Provider Distribution Chart
    const providerCtx = document.getElementById('providerChart').getContext('2d');
    new Chart(providerCtx, {
        type: 'doughnut',
        data: {
            labels: {{{json providerLabels}}},
            datasets: [{
                data: {{{json providerData}}},
                backgroundColor: [
                    '#10b981', '#3b82f6', '#f59e0b', '#ef4444', '#8b5cf6'
                ]
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { position: 'bottom' }
            }
        }
    });
</script>