<div class="bg-white border-b border-gray-200 px-6 py-4">
    <div class="flex justify-between items-center">
        <div>
            <h2 class="text-2xl font-semibold text-gray-800">{{pageTitle}}</h2>
            <p class="text-sm text-gray-500 mt-1">{{pageSubtitle}}</p>
        </div>
        
        <div class="flex items-center gap-4">
            <!-- Date/Time -->
            <div class="text-right">
                <p class="text-sm text-gray-500" id="current-date"></p>
                <p class="text-xs text-gray-400" id="current-time"></p>
            </div>
            
            <!-- Refresh Button -->
            <button onclick="location.reload()" class="p-2 hover:bg-gray-100 rounded-lg transition">
                <i class="fas fa-sync-alt text-gray-500"></i>
            </button>
        </div>
    </div>
</div>

<script>
    function updateDateTime() {
        const now = new Date();
        document.getElementById('current-date').innerHTML = now.toLocaleDateString('en-US', { 
            weekday: 'long', 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
        });
        document.getElementById('current-time').innerHTML = now.toLocaleTimeString('en-US');
    }
    updateDateTime();
    setInterval(updateDateTime, 1000);
</script>