<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <div class="sidebar-brand-logo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
            </svg>
        </div>
        <div>
            <h1>Admin Panel</h1>
            <p>Dashboard Overview</p>
        </div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-label">Menu</div>
        <a class="nav-link {{#if activeDashboard}}active{{/if}}" href="/admin/dashboard">
            <i class="fas fa-chart-line"></i> Dashboard
        </a>
        <a class="nav-link {{#if activeApplications}}active{{/if}}" href="/admin/api-keys">
            <i class="fas fa-key"></i> API Keys
        </a>
        <a class="nav-link {{#if activeUsers}}active{{/if}}" href="/admin/users">
            <i class="fas fa-users"></i> Users
        </a>
        <a class="nav-link {{#if activeSettings}}active{{/if}}" href="/admin/providers">
            <i class="fas fa-robot"></i> Providers
        </a>
        <a class="nav-link {{#if activeSettings}}active{{/if}}" href="/admin/analytics">
            <i class="fas fa-chart-pie"></i> Analytics
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-user">
            <div class="user-avatar" style="background-color: {{avatarColor adminName}}">{{initial adminName}}</div>
            <div class="user-meta">
                <div class="user-name">{{adminName}}</div>
                <div class="user-role">{{adminRole}}</div>
            </div>
            <i class="fas fa-ellipsis" style="color: rgba(255,255,255,0.3); font-size: 12px;"></i>
        </div>
    </div>
</aside>