<div>
    <div class="flex items-center gap-3 mb-2">
        <span class="text-xs font-bold uppercase tracking-widest px-2.5 py-1 rounded bg-indigo-50 text-indigo-800 border border-indigo-200">Core Engine</span>
    </div>
    <h1 class="text-3xl font-black tracking-tight text-slate-900 mb-4">Chat Completion API Layer</h1>
    
    <p class="text-slate-600 mb-6 leading-relaxed">
        Dispatches message arrays through highly optimized connection instances with transparent execution retry layers handling cross-model transformations automatically.
    </p>

    <h2 class="text-xl font-bold text-slate-900 mb-3">Endpoint Structure</h2>
    <div class="flex items-center gap-3 bg-slate-900 border border-slate-800 rounded-xl p-3.5 mb-8 font-mono text-sm shadow-inner">
        <span class="px-2.5 py-0.5 rounded text-xs font-extrabold text-white bg-emerald-600">POST</span>
        <span class="text-slate-200">/api/chat</span>
    </div>

    <h2 class="text-xl font-bold text-slate-900 mb-3">Payload Paradigm Spec</h2>
    <pre><code class="language-json">{
  "messages": [
    {
      "role": "user",
      "content": "Explain core caching patterns."
    }
  ],
  "model": "gpt-4o",
  "temperature": 0.7,
  "maxTokens": 1000,
  "preferredProvider": "OPENAI"
}</code></pre>

    <h2 class="text-xl font-bold text-slate-900 mt-8 mb-4">Request Field Configurations</h2>
    <div class="overflow-hidden border border-slate-200 rounded-xl shadow-sm mb-8">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-4 py-3 text-left font-semibold text-slate-700">Parameter</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-700">Type</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-700">Required</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-700">Description Rule</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 text-slate-600 bg-white">
                <tr>
                    <td class="px-4 py-3 font-semibold text-slate-900">messages</td>
                    <td class="px-4 py-3 font-mono text-xs">Array</td>
                    <td class="px-4 py-3 text-orange-600 font-medium">True</td>
                    <td class="px-4 py-3 text-xs">Objects array processing <code>role</code> and context strings.</td>
                </tr>
                <tr>
                    <td class="px-4 py-3 font-semibold text-slate-900">model</td>
                    <td class="px-4 py-3 font-mono text-xs">String</td>
                    <td class="px-4 py-3 text-slate-400">False</td>
                    <td class="px-4 py-3 text-xs">Target system weights string tag (e.g. <code>claude-3-5-sonnet</code>).</td>
                </tr>
                <tr>
                    <td class="px-4 py-3 font-semibold text-slate-900">temperature</td>
                    <td class="px-4 py-3 font-mono text-xs">Number</td>
                    <td class="px-4 py-3 text-slate-400">False</td>
                    <td class="px-4 py-3 text-xs">Probability spread variance metrics control boundaries [0-2]. Default 0.7</td>
                </tr>
                <tr>
                    <td class="px-4 py-3 font-semibold text-slate-900">preferredProvider</td>
                    <td class="px-4 py-3 font-mono text-xs">String</td>
                    <td class="px-4 py-3 text-slate-400">False</td>
                    <td class="px-4 py-3 text-xs">Target strict routing bypass parameters: <code>OPENAI</code>, <code>GEMINI</code>, etc.</td>
                </tr>
            </tbody>
        </table>
    </div>

    <h2 class="text-xl font-bold text-slate-900 mb-3">Unified Output Object Shape</h2>
    <pre><code class="language-json">{
  "success": true,
  "data": {
    "content": "Systems logic returned successfully.",
    "model": "gpt-4o",
    "provider": "OPENAI",
    "usage": {
      "promptTokens": 15,
      "completionTokens": 120,
      "totalTokens": 135
    },
    "latency": 342
  }
}</code></pre>

    <div class="mt-12 border-t border-slate-200 pt-8">
        <div class="bg-slate-900 text-white rounded-2xl p-6 lg:p-8 shadow-xl border border-slate-800">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h3 class="text-lg font-bold text-white tracking-tight">API Request Sandbox Terminal</h3>
                    <p class="text-xs text-slate-400">Dispatch live exploratory testing requests directly across node loops.</p>
                </div>
                <i class="fas fa-terminal text-slate-700 text-xl"></i>
            </div>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Target Client Key Credentials</label>
                    <input type="password" id="apiKeyInput" class="w-full px-3.5 py-2.5 bg-slate-950 border border-slate-800 rounded-lg text-sm text-slate-200 focus:outline-none focus:border-slate-700 transition" placeholder="Paste structural X-API-Key string context">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Prompt Input String Area</label>
                    <textarea id="messageInput" rows="3" class="w-full px-3.5 py-2.5 bg-slate-950 border border-slate-800 rounded-lg text-sm text-slate-200 focus:outline-none focus:border-slate-700 transition placeholder:text-slate-600" placeholder="Ask anything...">Explain quantum computing structure simply.</textarea>
                </div>
                
                <button onclick="testChatAPI()" class="w-full font-bold text-sm text-white py-3 rounded-lg transition-transform hover:scale-[1.01]" style="background-color: #DE6A2C;">
                    <i class="fas fa-bolt mr-2"></i>Execute Endpoint Evaluation
                </button>
                
                <div id="responseArea" class="mt-6 hidden">
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Response Stream Packet Output</label>
                    <pre class="bg-slate-950 border border-slate-800 p-4 rounded-xl text-xs max-h-64 overflow-y-auto"><code id="responseContent" class="text-emerald-400"></code></pre>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
async function testChatAPI() {
    const apiKey = document.getElementById('apiKeyInput').value;
    const message = document.getElementById('messageInput').value;
    const responseArea = document.getElementById('responseArea');
    const responseContent = document.getElementById('responseContent');
    
    if (!apiKey) {
        alert('Credentials required context dropped.');
        return;
    }
    
    try {
        responseContent.textContent = "Processing active connection vectors...";
        responseArea.classList.remove('hidden');
        
        const response = await axios.post('/api/chat', {
            messages: [{ role: 'user', content: message }],
            temperature: 0.7
        }, {
            headers: {
                'X-API-Key': apiKey,
                'Content-Type': 'application/json'
            }
        });
        
        responseContent.textContent = JSON.stringify(response.data, null, 2);
    } catch (error) {
        responseContent.textContent = "Error: " + (error.response?.data?.message || error.message);
    }
}
</script>