<!-- views/docs/index.hbs -->
<div>
    <h1 class="text-3xl font-bold text-gray-800 mb-4">Welcome to AI Gateway API</h1>
    <p class="text-gray-600 mb-8">
        A unified API interface to interact with multiple AI providers including OpenAI, Anthropic, Gemini, and Mistral.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="border rounded-lg p-6 hover:shadow-lg transition">
            <i class="fas fa-bolt text-purple-600 text-3xl mb-3"></i>
            <h3 class="font-semibold text-lg mb-2">Fast & Reliable</h3>
            <p class="text-gray-600 text-sm">Low latency responses with automatic failover between providers</p>
        </div>
        <div class="border rounded-lg p-6 hover:shadow-lg transition">
            <i class="fas fa-shield-alt text-purple-600 text-3xl mb-3"></i>
            <h3 class="font-semibold text-lg mb-2">Secure & Encrypted</h3>
            <p class="text-gray-600 text-sm">All API keys are encrypted and requests are authenticated</p>
        </div>
        <div class="border rounded-lg p-6 hover:shadow-lg transition">
            <i class="fas fa-chart-line text-purple-600 text-3xl mb-3"></i>
            <h3 class="font-semibold text-lg mb-2">Usage Tracking</h3>
            <p class="text-gray-600 text-sm">Monitor your token usage and costs in real-time</p>
        </div>
    </div>

    <h2 class="text-2xl font-bold text-gray-800 mb-4" id="introduction">Quick Start</h2>
    <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
        <p class="text-blue-800 text-sm">
            <strong>New to AI Gateway?</strong> Get your API key from the <a href="/auth/login" class="underline">developer portal</a> and start making requests in minutes.
        </p>
    </div>

    <h3 class="text-xl font-semibold text-gray-800 mb-3">Base URL</h3>
    <pre><code class="language-bash">https://api.yourdomain.com</code></pre>

    <h3 class="text-xl font-semibold text-gray-800 mt-8 mb-3">Authentication</h3>
    <p class="text-gray-600 mb-3">All API requests require an API key in the header:</p>
    <pre><code class="language-bash">X-API-Key: your-api-key-here</code></pre>

    <h3 class="text-xl font-semibold text-gray-800 mt-8 mb-3">Make Your First Request</h3>
    <pre><code class="language-javascript">const axios = require('axios');

const response = await axios.post('https://api.yourdomain.com/api/chat', {
  messages: [
    { role: 'user', content: 'Hello, AI!' }
  ]
}, {
  headers: {
    'X-API-Key': 'your-api-key-here',
    'Content-Type': 'application/json'
  }
});

console.log(response.data);</code></pre>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mt-8">
        <p class="text-green-800 text-sm">
            <i class="fas fa-check-circle mr-2"></i>
            Ready to start? Explore the specific API endpoints using the navigation menu.
        </p>
    </div>
</div>