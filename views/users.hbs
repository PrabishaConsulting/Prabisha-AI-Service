<div class="space-y-6">
    <h2 class="text-2xl font-bold text-gray-800">Users</h2>
    
    <div class="grid grid-cols-1 gap-6">
        {{#each users}}
        <div class="card p-6">
            <div class="flex items-start justify-between">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-bold">
                        {{#if name}}{{name.charAt0}}{{else}}{{email.charAt0}}{{/if}}
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold">{{name}}</h3>
                        <p class="text-gray-500 text-sm">{{email}}</p>
                        <span class="inline-block mt-1 px-2 py-1 bg-purple-100 text-purple-700 rounded text-xs">
                            {{role}}
                        </span>
                    </div>
                </div>
                <div class="text-right">
                    <p class="text-sm text-gray-500">Joined: {{formatTime createdAt}}</p>
                    <p class="text-sm text-gray-500">API Keys: {{apiKeys.length}}</p>
                </div>
            </div>
            
            {{#if usageLogs.length}}
            <div class="mt-4 pt-4 border-t border-gray-200">
                <h4 class="text-sm font-medium mb-2">Recent Activity</h4>
                <div class="space-y-2">
                    {{#each usageLogs}}
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">{{endpointPath}}</span>
                        <span class="text-gray-400">{{formatTime createdAt}}</span>
                    </div>
                    {{/each}}
                </div>
            </div>
            {{/if}}
        </div>
        {{/each}}
    </div>
</div>