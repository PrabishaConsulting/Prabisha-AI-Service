<div class="space-y-6">
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">User Identity Registry</h2>
        <p class="text-sm text-slate-500 mt-0.5">Supervise enterprise consumer identities, credential roles, and transaction loop histories.</p>
    </div>
    
    <div class="grid grid-cols-1 gap-4">
        {{#each users}}
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-xs text-white uppercase tracking-wider" style="background-color: #111CA8;">
                        {{#if name}}{{name.charAt 0}}{{else}}{{email.charAt 0}}{{/if}}
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900 text-base leading-none">{{name}}</h3>
                        <p class="text-xs font-mono text-slate-400 mt-1.5">{{email}}</p>
                        <span class="inline-block mt-2 px-2 py-0.5 border border-slate-200 bg-slate-50 text-slate-700 rounded font-bold text-[10px] uppercase tracking-wider">
                            System Permission Level: {{role}}
                        </span>
                    </div>
                </div>
                
                <div class="sm:text-right font-medium text-xs text-slate-500 space-y-1">
                    <div>Enrolled Identity Tick: <span class="text-slate-900 font-mono">{{formatTime createdAt}}</span></div>
                    <div>Provisioned Keys Linked: <span class="text-slate-900 font-bold">{{apiKeys.length}} keys</span></div>
                </div>
            </div>
            
            {{#if usageLogs.length}}
            <div class="mt-5 pt-4 border-t border-slate-100">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Live Session Logs Channel</h4>
                <div class="bg-slate-50 border border-slate-100 rounded-lg divide-y divide-slate-200/60 font-mono text-[11px] px-4 py-1.5 shadow-inner max-h-32 overflow-y-auto">
                    {{#each usageLogs}}
                    <div class="flex justify-between py-2 text-slate-600">
                        <span class="truncate pr-4"><span class="text-indigo-800 font-semibold">POST</span> -> {{endpointPath}}</span>
                        <span class="text-slate-400 shrink-0">{{formatTime createdAt}}</span>
                    </div>
                    {{/each}}
                </div>
            </div>
            {{/if}}
        </div>
        {{/each}}
    </div>
</div>