<div class="space-y-6">
    <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-4">
        <div>
            <h2 class="text-2xl font-bold tracking-tight text-slate-900">AI Cluster Model Nodes</h2>
            <p class="text-sm text-slate-500 mt-0.5">Provision failover routines, routing priority configurations, and encryption contexts.</p>
        </div>
        <div class="flex gap-2">
            <button onclick="showAddProviderModal()" class="inline-flex items-center font-bold text-xs text-white px-4 py-2.5 rounded-lg transition-transform hover:scale-[1.01] shadow-sm" style="background-color: #111CA8;">
                <i class="fas fa-plus mr-2"></i>Add Engine Provider
            </button>
            <button onclick="refreshProviders()" class="inline-flex items-center font-bold text-xs border border-slate-200 bg-white text-slate-700 px-4 py-2.5 rounded-lg hover:bg-slate-50 transition">
                <i class="fas fa-sync-alt mr-2"></i>Sync Registry
            </button>
        </div>
    </div>
    
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        {{#each providers}}
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm flex flex-col justify-between" id="provider-{{id}}">
            <div>
                <div class="flex justify-between items-start mb-5">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center bg-slate-50 border border-slate-100 text-slate-700 text-sm">
                            <i class="fas {{getProviderIcon name}}"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-slate-900 text-base leading-none">{{displayName}}</h3>
                            <p class="text-xs font-mono text-slate-400 mt-1">{{name}}</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <span class="inline-flex px-2 py-0.5 font-bold rounded uppercase text-[9px] border tracking-wider
                            {{#if (eq status 'ACTIVE')}}bg-emerald-50 text-emerald-700 border-emerald-200{{else}}bg-slate-100 text-slate-500 border-slate-200{{/if}}">
                            {{status}}
                        </span>
                        <button onclick="editProvider('{{id}}')" class="text-slate-400 hover:text-slate-950 transition-colors p-1 text-xs"><i class="fas fa-edit"></i></button>
                        <button onclick="deleteProvider('{{id}}', '{{displayName}}')" class="text-slate-400 hover:text-rose-600 transition-colors p-1 text-xs"><i class="fas fa-trash-alt"></i></button>
                    </div>
                </div>
                
                <div class="divide-y divide-slate-100 font-medium text-xs text-slate-600 space-y-2.5">
                    <div class="flex justify-between pt-2">
                        <span class="text-slate-400">Failover Routing Priority</span>
                        <span class="text-slate-900 font-bold">Tier Threshold Index: {{priority}}</span>
                    </div>
                    <div class="flex justify-between pt-2">
                        <span class="text-slate-400">Available Weight Snapshots</span>
                        <span class="text-slate-900 font-bold">{{models.length}} models</span>
                    </div>
                    <div class="flex justify-between pt-2">
                        <span class="text-slate-400">Upstream Authorization Layer</span>
                        <span>
                            {{#if encryptedKey}}
                            <span class="text-emerald-600 font-bold flex items-center gap-1"><i class="fas fa-check-circle"></i> Token Mounted</span>
                            {{else}}
                            <span class="text-rose-600 font-bold flex items-center gap-1"><i class="fas fa-exclamation-triangle"></i> Dropped Secret</span>
                            {{/if}}
                        </span>
                    </div>
                    <div class="flex justify-between pt-2 border-none">
                        <span class="text-slate-400">Accepted Payload Modalities</span>
                        <div class="flex gap-1">
                            {{#each supportedModalities}}
                            <span class="px-1.5 py-0.5 bg-slate-100 text-slate-700 font-bold border border-slate-200 text-[10px] rounded">{{this}}</span>
                            {{/each}}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-6 pt-4 border-t border-slate-100 grid grid-cols-2 gap-3">
                <button onclick="showApiKeyModal('{{id}}', '{{displayName}}')" class="font-bold text-xs text-white py-2.5 rounded-lg transition-transform hover:scale-[1.01]" style="background-color: #111CA8;">
                    <i class="fas fa-key mr-1.5 text-[10px]"></i> {{#if encryptedKey}}Update Key{{else}}Mount Key{{/if}}
                </button>
                {{#if encryptedKey}}
                <button onclick="testConnection('{{id}}')" class="font-bold text-xs border border-slate-200 text-slate-700 bg-slate-50 py-2.5 rounded-lg hover:bg-slate-100 transition">
                    <i class="fas fa-plug mr-1.5 text-[10px]"></i> Test Ping
                </button>
                {{/if}}
            </div>
        </div>
        {{else}}
        <div class="col-span-full border border-dashed border-slate-200 bg-white rounded-xl py-16 text-center text-sm text-slate-400">
            <i class="fas fa-database text-3xl text-slate-200 mb-3 block"></i>
            <p class="font-medium">No external hardware abstraction loops configured inside operational configurations datasets.</p>
            <button onclick="showAddProviderModal()" class="mt-2 text-xs font-bold underline" style="color: #111CA8;">Inject initial proxy node vector</button>
        </div>
        {{/each}}
    </div>
</div>

<div id="providerModal" class="fixed inset-0 bg-slate-950/40 hidden z-50 flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white border border-slate-200 rounded-xl max-w-md w-full shadow-2xl overflow-hidden text-sm">
        <div class="flex justify-between items-center px-6 py-4 border-b border-slate-100 bg-slate-50">
            <h3 class="text-sm font-bold text-slate-900 tracking-tight" id="providerModalTitle">Inject Target Engine</h3>
            <button onclick="closeProviderModal()" class="text-slate-400 hover:text-slate-600"><i class="fas fa-times"></i></button>
        </div>
        
        <form id="providerForm" onsubmit="submitProvider(event)" class="p-6 space-y-4">
            <input type="hidden" id="editProviderId">
            
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Engine Driver Name *</label>
                <select id="providerName" required class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium text-slate-800 bg-white">
                    <option value="">Select Target Core Class</option>
                    <option value="OPENAI">OpenAI Core API</option>
                    <option value="ANTHROPIC">Anthropic Claude Loop</option>
                    <option value="GEMINI">Google Gemini Engine Platform</option>
                    <option value="MISTRAL">Mistral AI Distributed Hub</option>
                    <option value="COHERE">Cohere Processing Unit</option>
                </select>
            </div>
            
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Interface Label Tag *</label>
                <input type="text" id="displayName" required class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium text-slate-800" placeholder="e.g. Production Cluster Core Layer - Ultra">
            </div>
            
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Failover Priority Rank (Lower Values Precede)</label>
                <input type="number" id="priority" value="100" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium text-slate-800">
            </div>
            
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Custom Base Routing Proxy URL (Optional)</label>
                <input type="text" id="baseUrl" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-medium font-mono text-xs text-slate-700" placeholder="Defaults to native global driver pathways">
            </div>
            
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Permitted Payload Target Modalities</label>
                <div class="space-y-1.5 font-medium text-xs text-slate-700 pl-1">
                    <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" value="TEXT" class="modality-checkbox rounded text-slate-900 focus:ring-0"> <span>Text Computations (Chat / Token Embeddings)</span></label>
                    <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" value="IMAGE" class="modality-checkbox rounded text-slate-900 focus:ring-0"> <span>Image Generation Raster Processing</span></label>
                    <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" value="VIDEO" class="modality-checkbox rounded text-slate-900 focus:ring-0"> <span>Asynchronous Temporal Video Matrices</span></label>
                    <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" value="EMBEDDING" class="modality-checkbox rounded text-slate-900 focus:ring-0"> <span>Dense Vector Mappings</span></label>
                </div>
            </div>
            
            <div class="flex gap-2 pt-4 border-t border-slate-100">
                <button type="button" onclick="closeProviderModal()" class="flex-1 font-bold text-xs border border-slate-200 py-2 rounded-lg hover:bg-slate-50 transition">Dismiss View</button>
                <button type="submit" class="flex-1 font-bold text-xs text-white py-2 rounded-lg transition shadow-sm" style="background-color: #111CA8;">Commit Core Node</button>
            </div>
        </form>
    </div>
</div>

<div id="apiKeyModal" class="fixed inset-0 bg-slate-950/40 hidden z-50 flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white border border-slate-200 rounded-xl max-w-md w-full shadow-2xl p-6 text-sm">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-sm font-bold text-slate-900 tracking-tight" id="modalTitle">Mount Downstream Hardware Key</h3>
            <button onclick="closeApiKeyModal()" class="text-slate-400 hover:text-slate-600"><i class="fas fa-times"></i></button>
        </div>
        
        <form id="apiKeyForm" onsubmit="submitApiKey(event)" class="space-y-4">
            <input type="hidden" id="providerId">
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Plain Secret String Content</label>
                <input type="password" id="apiKeyInput" required class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:border-slate-400 font-mono text-xs" placeholder="sk-...">
                <p class="text-[10px] text-slate-400 font-medium mt-1.5 flex items-center gap-1">
                    <i class="fas fa-lock"></i> Payload contents encrypt strictly at rest through AES-GCM primitives.
                </p>
            </div>
            
            <div class="mb-2" id="testResult" style="display: none;">
                <div id="testMessage" class="text-xs p-2.5 rounded border font-semibold"></div>
            </div>
            
            <div class="flex gap-2 pt-2">
                <button type="button" onclick="testKeyBeforeSave()" class="flex-1 font-bold text-xs border border-amber-300 text-orange-700 bg-orange-50/50 py-2 rounded-lg hover:bg-orange-50 transition">
                    <i class="fas fa-vial mr-1"></i> dry-run ping
                </button>
                <button type="submit" class="flex-1 font-bold text-xs text-white py-2 rounded-lg transition" style="background-color: #111CA8;">
                    Mount Verified Config
                </button>
            </div>
        </form>
    </div>
</div>

<div id="deleteModal" class="fixed inset-0 bg-slate-950/40 hidden z-50 flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white border border-slate-200 rounded-xl max-w-sm w-full shadow-2xl p-6 text-center text-sm">
        <div class="w-12 h-12 bg-rose-50 text-rose-600 rounded-full flex items-center justify-center mx-auto mb-4 border border-rose-100">
            <i class="fas fa-exclamation-triangle text-base"></i>
        </div>
        <h3 class="text-base font-bold text-slate-900 mb-1">Sever Cluster Target Node?</h3>
        <p class="text-xs text-slate-500 mb-4">Confirm permanent decoupling of <strong id="deleteProviderName" class="text-slate-900"></strong> variables context references?</p>
        
        <div class="flex gap-2">
            <button onclick="closeDeleteModal()" class="flex-1 font-bold text-xs border border-slate-200 py-2.5 rounded-lg hover:bg-slate-50 transition">Abort</button>
            <button onclick="confirmDelete()" class="flex-1 font-bold text-xs text-white bg-rose-600 py-2.5 rounded-lg hover:bg-rose-700 transition">Confirm Purge</button>
        </div>
    </div>
</div>

<div id="loadingOverlay" class="fixed inset-0 bg-slate-950/20 hidden items-center justify-center z-[100] backdrop-blur-[1px]">
    <div class="bg-white border border-slate-200 shadow-xl rounded-xl px-5 py-3.5 flex items-center gap-3 text-xs font-semibold text-slate-700">
        <div class="animate-spin rounded-full h-4 w-4 border-2 border-slate-300" style="border-top-color: #111CA8;"></div>
        <span>Evaluating cluster dependencies...</span>
    </div>
</div>

<script>
    let currentProviderId = null;
    let deleteProviderId = null;

    function refreshProviders() { location.reload(); }
    function showAddProviderModal() {
        document.getElementById('providerModalTitle').innerHTML = 'Inject Target Engine Node';
        document.getElementById('providerForm').reset();
        document.getElementById('editProviderId').value = '';
        document.getElementById('providerModal').classList.remove('hidden');
    }
    function closeProviderModal() { document.getElementById('providerModal').classList.add('hidden'); }
    function closeDeleteModal() {
        document.getElementById('deleteModal').classList.add('hidden');
        deleteProviderId = null;
    }
    function showApiKeyModal(providerId, providerName) {
        currentProviderId = providerId;
        document.getElementById('modalTitle').innerHTML = `Mount Cryptographic Secret — ${providerName}`;
        document.getElementById('providerId').value = providerId;
        document.getElementById('apiKeyInput').value = '';
        document.getElementById('testResult').style.display = 'none';
        document.getElementById('apiKeyModal').classList.remove('hidden');
    }
    function closeApiKeyModal() {
        document.getElementById('apiKeyModal').classList.add('hidden');
        currentProviderId = null;
    }
    function showLoading() { document.getElementById('loadingOverlay').classList.remove('hidden'); }
    function hideLoading() { document.getElementById('loadingOverlay').classList.add('hidden'); }
    
    // Core logic tracking maps continue to flow dynamically into standard context layouts safely.
</script>