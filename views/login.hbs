<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gradient-to-br from-purple-600 to-blue-500 min-h-screen">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="max-w-md w-full">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/20 backdrop-blur mb-4">
                    <i class="fas fa-robot text-4xl text-white"></i>
                </div>
                <h2 class="text-3xl font-bold text-white mb-2">AI Gateway</h2>
                <p class="text-purple-200">Centralized AI Microservice</p>
            </div>
            
            <div class="bg-white rounded-2xl shadow-2xl p-8">
                <div class="text-center mb-6">
                    <i class="fas fa-shield-alt text-5xl text-purple-600 mb-3"></i>
                    <h3 class="text-xl font-semibold text-gray-800">Admin Access Required</h3>
                    <p class="text-gray-600 text-sm mt-2">Sign in with your company credentials</p>
                </div>
                
                <a href="/auth/central" 
                   class="w-full flex items-center justify-center gap-3 px-6 py-3 bg-gradient-to-r from-purple-600 to-blue-500 hover:from-purple-700 hover:to-blue-600 text-white font-medium rounded-lg transition transform hover:scale-[1.02]">
                    <i class="fab fa-microsoft"></i>
                    Sign in with Central Auth
                </a>
                
                <div class="mt-6 pt-6 border-t border-gray-200">
                    <div class="flex items-center justify-center gap-2 text-xs text-gray-500">
                        <i class="fas fa-lock"></i>
                        <span>Secured by OIDC SSO</span>
                    </div>
                </div>
            </div>
            
            <div class="text-center mt-8 text-purple-200 text-xs">
                <p>© 2024 AI Gateway - All rights reserved</p>
            </div>
        </div>
    </div>
</body>
</html>